# ============================================================
# MADEVHUB Growth Engine — variables de entorno
# Copia este archivo a `.env` y rellena los valores reales.
#   cp .env.example .env
# El archivo `.env` está en .gitignore y NUNCA debe subirse.
# ============================================================

# ---------- BACKEND (server/index.js) ----------

# Clave de la API de Outscraper (obligatoria para buscar/enriquecer leads).
# Consíguela en https://app.outscraper.com/profile
OUTSCRAPER_API_KEY=

# Puerto del backend Express. Por defecto 4000.
PORT=4000

# URL del frontend permitida por CORS en producción.
# Déjalo vacío en desarrollo local (CORS abierto).
# Ejemplo producción: https://tuapp.com
FRONTEND_URL=

# Token de acceso para proteger los endpoints que gastan créditos.
# Si lo defines, cada request a /api/search-leads, /api/enrich-lead y
# /api/search-leads-with-emails debe enviar este token en la cabecera
# "x-access-token" o "Authorization: Bearer <token>".
# Déjalo vacío en desarrollo local para no exigir token.
# Genera uno seguro con:  openssl rand -hex 32
API_ACCESS_TOKEN=

# Rate limiting (opcional). Ventana en ms y máximo de requests por IP.
# Por defecto: 60 requests cada 15 minutos.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=60

# ---------- FRONTEND (Vite, prefijo VITE_) ----------

# URL del backend a la que llama el frontend. Por defecto http://localhost:4000
VITE_API_URL=http://localhost:4000

# Si configuraste API_ACCESS_TOKEN en el backend, ponlo aquí también para
# que el frontend lo envíe en cada request.
# NOTA: al ser una app de navegador, este valor queda visible en el bundle;
# sirve para frenar abuso casual y poder rotarlo, no como secreto absoluto.
# La protección real viene de CORS + rate limiting + este token combinados.
VITE_API_ACCESS_TOKEN=
